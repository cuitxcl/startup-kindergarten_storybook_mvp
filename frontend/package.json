{
  "name": "kindleaf-frontend-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:mock": "VITE_USE_API=false vite --host 127.0.0.1",
    "dev:api": "VITE_USE_API=true vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:mock": "VITE_USE_API=false tsc -b && VITE_USE_API=false vite build",
    "build:api": "VITE_USE_API=true VITE_API_BASE_URL=http://127.0.0.1:8080 tsc -b && VITE_USE_API=true VITE_API_BASE_URL=http://127.0.0.1:8080 vite build",
    "preview": "vite preview",
    "smoke:ui": "node ../scripts/smoke-ui.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
