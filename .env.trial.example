# Kindleaf trial deployment template
#
# Copy this file to .env.local or export these values in your shell before running:
#   ./scripts/check-smart.sh trial-strict
#
# Do not commit real secrets. Generate the auth token secret with:
#   openssl rand -base64 48

# Server
PORT=8080
APP_HOST=https://kindleaf.example.com
DATABASE_URL=postgres://kindleaf_user:change-me@db.example.com:5432/kindleaf_trial
KINDLEAF_DEMO_SEED=0

# Auth
# Required for trial. Must be a real random value, at least 32 characters.
KINDLEAF_AUTH_TOKEN_SECRET=replace-with-openssl-rand-base64-48
# 7 days. Maximum accepted by readiness is 2592000 seconds, or 30 days.
KINDLEAF_AUTH_TOKEN_TTL_SECONDS=604800

# Generation provider
# Leave empty to enable DeepSeek text + Seedream image auto-composite mode.
KINDLEAF_GENERATION_PROVIDER=

# DeepSeek text generation
DEEPSEEK_API_KEY=replace-with-real-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ENDPOINT_PATH=/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=45
DEEPSEEK_MAX_TOKENS=4096

# ByteDance Seedream image generation
# Configure either SEEDREAM_API_KEY or ARK_API_KEY.
SEEDREAM_API_KEY=
ARK_API_KEY=replace-with-real-ark-or-seedream-key
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com
ARK_BASE_URL=
SEEDREAM_ENDPOINT_PATH=/api/v3/images/generations
ARK_IMAGE_ENDPOINT_PATH=
SEEDREAM_IMAGE_MODEL=doubao-seedream-5-0-lite
ARK_IMAGE_MODEL=
SEEDREAM_IMAGE_SIZE=1024x1024
SEEDREAM_TIMEOUT_SECONDS=120

# Cost and budget
KINDLEAF_COST_CURRENCY=USD
KINDLEAF_COST_DEEPSEEK_INPUT_UNIT_MICROS=1
KINDLEAF_COST_DEEPSEEK_OUTPUT_UNIT_MICROS=4
KINDLEAF_COST_SEEDREAM_IMAGE_MICROS=40000
# Example: 2 USD budget cap if currency is USD.
KINDLEAF_COST_BUDGET_LIMIT_MICROS=2000000
KINDLEAF_COST_BUDGET_WARNING_PERCENT=80

# Storage
# Trial must use a persistent directory, not tmp.
# Prepare it on the deployment host before running trial-strict, for example:
#   sudo mkdir -p /var/lib/kindleaf/{exports,generated-images}
#   sudo chown -R <kindleaf-runtime-user>:<kindleaf-runtime-group> /var/lib/kindleaf
KINDLEAF_STORAGE_ROOT=/var/lib/kindleaf
KINDLEAF_EXPORTS_DIR=
KINDLEAF_GENERATED_IMAGES_DIR=
KINDLEAF_EXPORT_MAX_BYTES=52428800
KINDLEAF_GENERATED_IMAGE_MAX_BYTES=15728640
