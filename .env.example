# Server
# 本地演示可用 127.0.0.1；外部试点应使用真实 HTTPS 域名。
PORT=8080
APP_HOST=http://127.0.0.1:8080
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:55432/kindleaf_development
# 本地演示或 smoke 可设为 1；真实试点不要开启。
KINDLEAF_DEMO_SEED=0
# 外部试点必须配置，至少 32 字符。配置后登录返回带过期时间的签名 token。
KINDLEAF_AUTH_TOKEN_SECRET=
KINDLEAF_AUTH_TOKEN_TTL_SECONDS=604800

# Generation provider
# 本地演示使用 mock。
KINDLEAF_GENERATION_PROVIDER=mock
# 真实试点推荐 DeepSeek + Seedream 组合模式：
# 1. 在实际 .env 中把 KINDLEAF_GENERATION_PROVIDER 显式留空：KINDLEAF_GENERATION_PROVIDER=
# 2. 同时配置 DEEPSEEK_API_KEY 和 SEEDREAM_API_KEY 或 ARK_API_KEY。
# 3. 运行 ./scripts/check-trial-readiness.sh --strict 检查试点配置。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ENDPOINT_PATH=/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=45
DEEPSEEK_MAX_TOKENS=4096
SEEDREAM_API_KEY=
# 如果使用火山方舟已有命名，也可以只配置 ARK_API_KEY。
ARK_API_KEY=
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com
# 火山方舟兼容别名；未配置 SEEDREAM_BASE_URL 时可使用。
ARK_BASE_URL=
SEEDREAM_ENDPOINT_PATH=/api/v3/images/generations
# 火山方舟图片 endpoint 兼容别名；未配置 SEEDREAM_ENDPOINT_PATH 时可使用。
ARK_IMAGE_ENDPOINT_PATH=
# 项目默认真实生图模型使用字节跳动 Seedream。
SEEDREAM_IMAGE_MODEL=doubao-seedream-5-0-lite
# 火山方舟图片模型兼容别名；未配置 SEEDREAM_IMAGE_MODEL 时可使用。
ARK_IMAGE_MODEL=
SEEDREAM_IMAGE_SIZE=1024x1024
SEEDREAM_TIMEOUT_SECONDS=120

# Cost and budget
KINDLEAF_COST_CURRENCY=USD
KINDLEAF_COST_DEEPSEEK_INPUT_UNIT_MICROS=1
KINDLEAF_COST_DEEPSEEK_OUTPUT_UNIT_MICROS=4
KINDLEAF_COST_SEEDREAM_IMAGE_MICROS=40000
KINDLEAF_COST_BUDGET_LIMIT_MICROS=
KINDLEAF_COST_BUDGET_WARNING_PERCENT=80

# Storage
# 本地默认写入 tmp；试点建议使用持久化目录，例如 /var/lib/kindleaf。
KINDLEAF_STORAGE_ROOT=tmp
KINDLEAF_EXPORTS_DIR=
KINDLEAF_GENERATED_IMAGES_DIR=
KINDLEAF_EXPORT_MAX_BYTES=52428800
KINDLEAF_GENERATED_IMAGE_MAX_BYTES=15728640
